{
  "name": "waahtickets",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:server": "tsx src/index.ts",
    "dev:cloudflare": "npm run build && wrangler dev",
    "dev:cloudflare:lan": "npm run build && wrangler dev --ip 0.0.0.0 --port 8787",
    "dev:cloudflare:remote": "npm run build && wrangler dev --remote",
    "mobile:dev": "npm run dev --workspace @waahtickets/mobile",
    "mobile:dev:clear": "npm run dev:clear --workspace @waahtickets/mobile",
    "mobile:android": "npm run android --workspace @waahtickets/mobile",
    "mobile:ios": "npm run ios --workspace @waahtickets/mobile",
    "build": "vite build && tsc",
    "build:test": "npm run build && npm test",
    "test": "vitest run",
    "test:button-flow:local": "./scripts/test-create-order-button-flow-local.sh",
    "start": "node dist/index.js",
    "deploy": "npm run build && wrangler deploy",
    "db:create": "wrangler d1 create waahtickets-db",
    "db:migrate:local": "wrangler d1 migrations apply waahtickets-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply waahtickets-db --remote",
    "db:execute:local": "wrangler d1 execute waahtickets-db --local",
    "db:execute:remote": "wrangler d1 execute waahtickets-db --remote",
    "db:repair:org-users-role:local": "wrangler d1 execute waahtickets-db --local --file scripts/repair-org-users-role-column.sql",
    "db:repair:org-users-role:remote": "wrangler d1 execute waahtickets-db --remote --file scripts/repair-org-users-role-column.sql",
    "test:account-email-queue:local": "./scripts/test-account-email-queue-local.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "hono": "^4.7.4",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.11.0",
    "qrcode": "^1.5.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-native": "0.81.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260425.1",
    "@types/node": "^22.13.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  }
}
