{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "waahtickets",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-04-25",
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/health"]
  }
}
